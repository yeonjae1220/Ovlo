# =============================================
# Ovlo Docker 환경 설정 템플릿
# cp .env.example .env 후 값을 채워주세요
# =============================================

# [필수] JWT 서명 키 (최소 32바이트, Base64 인코딩) — 미설정 시 애플리케이션 시작 실패
# 생성: openssl rand -base64 32
JWT_SECRET=  # openssl rand -base64 32

# [필수] PostgreSQL 비밀번호 — 미설정 시 컨테이너 시작 실패
# 생성: openssl rand -base64 16
POSTGRES_PASSWORD=

# [필수] Redis 비밀번호 — 미설정 시 컨테이너 시작 실패
# 생성: openssl rand -base64 16
REDIS_PASSWORD=

# [필수] Google OAuth2 — GCP Console에서 발급
# 각 앱마다 별도 OAuth 클라이언트 생성 권장 (Ovlo / TimeManager / Snapguide 각각)
# GCP 승인된 리디렉션 URI 예시: https://ovlo.mungji.com/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# [선택] 프론트엔드 CORS 허용 도메인 (기본값: http://localhost:3000)
# 여러 도메인: http://localhost:3000,https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# [필수] Grafana 관리자 비밀번호 — 미설정 시 컨테이너 시작 실패
# 운영 배포 시 반드시 변경
GRAFANA_ADMIN_PASSWORD=

# [선택] 학생 인증 이메일(SMTP) — 4개를 모두 채우면 실제 발송, 비우면 Log 폴백(코드를 로그로만 출력)
# ⚠️ 빈 값으로 두면 Log 폴백 유지 — 절대 SPRING_MAIL_HOST만 빈 문자열로 설정하지 말 것
# Gmail 사용: 2단계 인증 후 "앱 비밀번호" 발급(myaccount.google.com/apppasswords) → MAIL_PASSWORD에 16자리
# Gmail은 From을 인증 계정으로 강제하므로 MAIL_FROM은 Gmail 주소(또는 'Send mail as' 별칭)와 동일하게
SPRING_MAIL_HOST=        # smtp.gmail.com
MAIL_USERNAME=           # your-account@gmail.com
MAIL_PASSWORD=           # Gmail 앱 비밀번호 16자리(공백 제거)
MAIL_FROM=               # your-account@gmail.com
