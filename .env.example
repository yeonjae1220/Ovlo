# =============================================
# Ovlo Docker 환경 설정 템플릿
# cp .env.example .env 후 값을 채워주세요
# =============================================

# [필수] JWT 서명 키 (최소 32바이트, Base64 인코딩)
# 생성: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production-minimum-32-bytes

# [선택] PostgreSQL 비밀번호 (기본값: ovlo)
# 로컬 개발은 기본값 사용 가능, 운영 배포 시 반드시 변경
POSTGRES_PASSWORD=ovlo

# [선택] 프론트엔드 CORS 허용 도메인 (기본값: http://localhost:3000)
# 여러 도메인: http://localhost:3000,https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# [선택] Grafana 관리자 비밀번호 (기본값: admin)
# 운영 배포 시 반드시 변경
GRAFANA_ADMIN_PASSWORD=admin
